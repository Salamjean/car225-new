                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"type\": \"objet_oublie\",\n  \"reservation_id\": 1,\n  \"objet\": \"Téléphone Samsung Galaxy S21\",\n  \"description\": \"J'ai oublié mon téléphone sous le siège numéro 12 du bus. Il est de couleur noire avec une coque transparente.\"\n}"
                },
