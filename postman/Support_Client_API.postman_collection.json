                        "support"
                    ]
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"type\": \"remboursement\",\n  \"reservation_id\": 1,\n  \"objet\": \"Remboursement réservation annulée du 15/02\",\n  \"description\": \"Mon voyage a été annulé par la compagnie mais je n'ai pas encore reçu le remboursement sur mon portefeuille.\"\n}"
                },
                "description": "⚠️ reservation_id est OBLIGATOIRE pour ce type. Doit être une réservation annulée."
