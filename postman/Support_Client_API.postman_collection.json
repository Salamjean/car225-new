                        "user",
                        "support",
                        "categories"
                    ]
                },
                "description": "Retourne toutes les catégories de support disponibles avec leurs métadonnées.\n\nRéponse :\n{\n  \"success\": true,\n  \"categories\": [\n    {\n      \"id\": \"bagage_perdu\",\n      \"title\": \"Bagage Perdu\",\n      \"description\": \"...\",\n      \"icon\": \"suitcase-rolling\",\n      \"color\": \"#e94f1b\",\n      \"needs_reservation\": true,\n      \"placeholder_object\": \"...\",\n      \"placeholder_description\": \"...\"\n    },\n    ...\n  ]\n}"
            }
