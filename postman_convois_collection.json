                  "pm.test('Success true', () => pm.expect(res.success).to.be.true);",
                  "pm.test('Nombre passagers retourné', () => pm.expect(res.passagers_count).to.be.a('number'));",
                  "console.log('Passagers restants :', res.passagers_count);"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept",         "value": "application/json" },
              { "key": "Authorization",  "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/user/convois/{{convoi_id}}/passagers/{{passager_id}}",
              "host": ["{{base_url}}"],
              "path": ["user","convois","{{convoi_id}}","passagers","{{passager_id}}"]
            }
          }
        }
      ]
    },

