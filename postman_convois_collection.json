                  "});",
                  "if (res.convoi.passagers.length > 0) {",
                  "    pm.collectionVariables.set('passager_id', res.convoi.passagers[0].id);",
                  "    console.log('Premier passager ID sauvegardé :', res.convoi.passagers[0].id);",
                  "}"
                ]
