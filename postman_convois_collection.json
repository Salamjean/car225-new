              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/user/convois-form/compagnies/1/itineraires",
              "host": ["{{base_url}}"],
              "path": ["user","convois-form","compagnies","1","itineraires"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Array itineraires', () => pm.expect(res.itineraires).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Règlement des convois",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
