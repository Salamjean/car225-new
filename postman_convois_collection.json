      ]
    },

    {
      "name": "🚌 Convois CRUD",
      "item": [
        {
          "name": "Mes convois (liste)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Success true', () => pm.expect(res.success).to.be.true);",
                  "pm.test('Pagination présente', () => pm.expect(res.pagination).to.be.an('object'));",
                  "pm.test('Data est un array', () => pm.expect(res.data).to.be.an('array'));",
                  "if (res.data.length > 0) {",
                  "    pm.collectionVariables.set('convoi_id', res.data[0].id);",
                  "    console.log('Premier convoi ID sauvegardé :', res.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/user/convois?per_page=10",
              "host": ["{{base_url}}"],
              "path": ["user","convois"],
              "query": [
                { "key": "per_page", "value": "10" },
                { "key": "statut",   "value": "",   "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Mes convois — filtre statut (paye)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/user/convois?statut=paye",
              "host": ["{{base_url}}"],
              "path": ["user","convois"],
              "query": [{ "key": "statut", "value": "paye" }]
            }
          }
        },
        {
          "name": "Créer un convoi (avec itinéraire)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "pm.test('Success true', () => pm.expect(res.success).to.be.true);",
                  "pm.test('Référence générée', () => pm.expect(res.convoi.reference).to.match(/^CONV-/));",
                  "pm.test('Statut en_attente', () => pm.expect(res.convoi.statut).to.eql('en_attente'));",
                  "pm.collectionVariables.set('convoi_id', res.convoi.id);",
                  "console.log('Nouveau convoi ID :', res.convoi.id, '| Ref :', res.convoi.reference);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"compagnie_id\": 1,\n  \"gare_id\": 1,\n  \"itineraire_id\": 1,\n  \"nombre_personnes\": 15,\n  \"date_depart\": \"2026-05-10\",\n  \"heure_depart\": \"08:00\",\n  \"date_retour\": null,\n  \"heure_retour\": null\n}"
            },
            "url": { "raw": "{{base_url}}/user/convois", "host": ["{{base_url}}"], "path": ["user","convois"] }
          }
        },
        {
          "name": "Créer un convoi (trajet personnalisé)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "pm.test('Lieu départ enregistré', () => pm.expect(res.convoi.lieu_depart).to.eql('Cocody, Abidjan'));",
                  "pm.collectionVariables.set('convoi_id', res.convoi.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
