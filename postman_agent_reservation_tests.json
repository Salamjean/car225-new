{
    "info": {
        "name": "Car225 - Agent Reservation API",
        "_postman_id": "car225-agent-reservation-api",
        "description": "Collection de tests pour l'API Agent Reservation de Car225.\n\n## Configuration\n1. Importer cette collection dans Postman\n2. Créer un environnement avec les variables:\n   - `base_url` = http://127.0.0.1:8000/api\n   - `agent_token` = (sera rempli automatiquement après login)\n3. Exécuter d'abord le login pour obtenir le token",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://127.0.0.1:8000/api"
        },
        {
            "key": "agent_token",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "🔐 Authentification",
            "item": [
                {
                    "name": "1. Login Agent (code_id)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.token) {",
                                    "    pm.collectionVariables.set('agent_token', jsonData.token);",
                                    "    console.log('Token saved:', jsonData.token);",
                                    "}",
                                    "",
                                    "pm.test('Login successful', function () {",
                                    "    pm.expect(pm.response.code).to.be.oneOf([200]);",
                                    "    pm.expect(jsonData.token).to.not.be.undefined;",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"code_id\": \"AGT-XXXXXX\",\n    \"password\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/unified-login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "unified-login"
                            ]
                        }
                    }
                },
                {
                    "name": "2. Logout Agent",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{agent_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/agent/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "agent",
                                "logout"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "📋 Réservations",
            "item": [
                {
                    "name": "3. Liste des réservations + programmes du jour",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                                    "pm.test('Has programmes_du_jour', function() { pm.expect(jsonData.programmes_du_jour).to.not.be.undefined; });",
                                    "pm.test('Has en_cours', function() { pm.expect(jsonData.en_cours).to.not.be.undefined; });",
                                    "pm.test('Has terminees', function() { pm.expect(jsonData.terminees).to.not.be.undefined; });",
                                    "pm.test('Has pagination', function() { pm.expect(jsonData.pagination).to.not.be.undefined; });"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{agent_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/agent/reservations",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "agent",
                                "reservations"
                            ]
                        }
                    }
                },
                {
                    "name": "3b. Liste avec filtre statut",
                    "request": {
                        "method": "GET",
                        "header": [
