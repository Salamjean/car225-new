                {
                    "name": "4. Détails d'une réservation",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                                    "pm.test('Has reservation', function() { pm.expect(jsonData.reservation).to.not.be.undefined; });",
                                    "pm.test('Has montant', function() { pm.expect(jsonData.reservation.montant).to.not.be.undefined; });"
                                ],
