                        "url": {
                            "raw": "{{base_url}}/agent/reservations/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "agent",
                                "reservations",
                                "1"
                            ],
                            "variable": [
                                {
                                    "key": "reservationId",
                                    "value": "1",
                                    "description": "ID de la réservation"
                                }
                            ]
                        }
                    }
                }
            ]
